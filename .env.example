# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=learning_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=learning_platform

# JWT密钥
SECRET_KEY=your-secret-key-change-this-in-production

# AI服务配置
OCR_PROVIDER=baidu
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key

ALIYUN_OCR_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_OCR_ACCESS_KEY_SECRET=your-aliyun-access-key-secret

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key

WENXIN_API_KEY=your-wenxin-api-key
WENXIN_SECRET_KEY=your-wenxin-secret-key

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 前端配置
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:8000
